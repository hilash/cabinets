graph TD
    Student["🦸 You"]
    Mentor["🎓 Mentor"]
    Math["📐 Math Tutor"]
    Code["💻 Code Tutor"]
    Tracker["📊 Progress Tracker"]

    Student --> Mentor
    Mentor --> Math
    Mentor --> Code
    Mentor --> Tracker

    style Student fill:#F5E6D3,stroke:#8B5E3C,color:#3B2F2F
    style Mentor fill:#F5E6D3,stroke:#8B5E3C,color:#3B2F2F
    style Math fill:#fff,stroke:#D4C4B0,color:#3B2F2F
    style Code fill:#fff,stroke:#D4C4B0,color:#3B2F2F
    style Tracker fill:#fff,stroke:#D4C4B0,color:#3B2F2F
