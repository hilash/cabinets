    style Ranger fill:#fff,stroke:#D4C4B0,color:#3B2F2F
    style Hunter fill:#fff,stroke:#D4C4B0,color:#3B2F2F
    style Foodie fill:#fff,stroke:#D4C4B0,color:#3B2F2F
    style Holiday fill:#fff,stroke:#D4C4B0,color:#3B2F2F
