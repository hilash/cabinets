graph TD
    subgraph Sourcing
        LEAD["📞 Lead Intake"]
        QUAL["✅ Qualification"]
    end

    subgraph Listing
        PREP["📸 Listing Prep"]
        PHOTO["🖼️ Photography"]
        PRICE["💰 Pricing Strategy"]
        PUB["🌐 Publish Listing"]
    end

    subgraph Marketing
        MKT["📣 Marketing Specialist"]
        OPEN["🏠 Open Houses"]
        ADS["📱 Digital Ads"]
    end

    subgraph Closing
        OFFER["📝 Offers"]
        NEG["🤝 Negotiation"]
        CLOSE["🎉 Closing"]
    end

    LEAD --> QUAL
    QUAL -->|qualified| PREP
    QUAL -->|not ready| LEAD
    PREP --> PHOTO
    PREP --> PRICE
    PHOTO --> PUB
    PRICE --> PUB
    PUB --> MKT
    MKT --> OPEN
    MKT --> ADS
    OPEN --> OFFER
    ADS --> OFFER
    OFFER --> NEG
    NEG -->|accepted| CLOSE
    NEG -->|counter| OFFER

    style LEAD fill:#FAF2EA,stroke:#D4C4B0,color:#3B2F2F
    style QUAL fill:#FAF2EA,stroke:#D4C4B0,color:#3B2F2F
    style PREP fill:#fff,stroke:#D4C4B0,color:#3B2F2F
    style PHOTO fill:#fff,stroke:#D4C4B0,color:#3B2F2F
    style PRICE fill:#fff,stroke:#D4C4B0,color:#3B2F2F
    style PUB fill:#F5E6D3,stroke:#8B5E3C,color:#3B2F2F
    style MKT fill:#F5E6D3,stroke:#8B5E3C,color:#3B2F2F
    style OPEN fill:#fff,stroke:#D4C4B0,color:#3B2F2F
    style ADS fill:#fff,stroke:#D4C4B0,color:#3B2F2F
    style OFFER fill:#FAF2EA,stroke:#D4C4B0,color:#3B2F2F
    style NEG fill:#FAF2EA,stroke:#D4C4B0,color:#3B2F2F
    style CLOSE fill:#F5E6D3,stroke:#8B5E3C,color:#3B2F2F
